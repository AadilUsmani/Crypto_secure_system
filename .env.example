# Database Configuration
# For SQLite (local development): sqlite:///./app.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
# For MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./app.db

# Logging Configuration (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# SQL Query Logging (enable for debugging slow queries)
# WARNING: Very verbose! Only enable during development
SQL_ECHO=false

# Connection Pool Settings (ignored for SQLite)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Security & Authentication
# Generate a strong SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-strong-random-value-in-production
ALGORITHM=HS256

# JWT token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Argon2 Password Hashing Parameters (production tuning)
# time_cost: iterations (2-3 for responsive servers, 4+ for background tasks)
# memory_cost: KiB (65536 = 64MB is standard for web; increase for higher security)
# parallelism: threads (4 typical for multi-core systems)
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

